# Git ignore for BibEasy
# =======================

# ------------------------------------------------------------------------------
# Python
# ------------------------------------------------------------------------------

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Translations
*.mo
*.pot

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# pytype
.pytype/

# Cython debug symbols
cython_debug/

# ------------------------------------------------------------------------------
# Node.js / Frontend
# ------------------------------------------------------------------------------

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Build outputs
/frontend/dist
/frontend/build
/backend/static

# Dependency directories
jspm_packages/

# TypeScript cache
*.tsbuildinfo

# Vite
/frontend/.vite

# ------------------------------------------------------------------------------
# IDEs and Editors
# ------------------------------------------------------------------------------

# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json

# JetBrains (PyCharm, WebStorm, etc.)
.idea/

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# Sublime Text
*.sublime-workspace

# ------------------------------------------------------------------------------
# Operating System
# ------------------------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~

# ------------------------------------------------------------------------------
# Project Specific
# ------------------------------------------------------------------------------

# Local data
backend/data/
/data/

# Logs
*.log
logs/

# Secrets (NUNCA commitar!)
*.pem
*.key
secrets/

# Database files
*.db
*.sqlite
*.sqlite3

# Uploads
uploads/

# Temporary files
tmp/
temp/
*.tmp
*.temp

# Session files
.session/

# Documentation builds
docs/_build/
site/

# ------------------------------------------------------------------------------
# Docker
# ------------------------------------------------------------------------------

# Docker Compose override (local customizations)
docker-compose.override.yml

# Docker volumes
.docker/
