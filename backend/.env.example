# ==============================================================================
# bibsimples - Configurações de Ambiente
# ==============================================================================
#
# Copie este arquivo para .env e ajuste os valores conforme necessário.
# NUNCA commite o arquivo .env com dados sensíveis!
#
# As variáveis usam o prefixo BIBSIMPLES_ para evitar conflitos.
# ==============================================================================

# ------------------------------------------------------------------------------
# Configurações Gerais
# ------------------------------------------------------------------------------

# Ativa modo debug (mais logs, reload automático)
BIBSIMPLES_DEBUG=true

# ------------------------------------------------------------------------------
# Configurações do Biblivre
# ------------------------------------------------------------------------------

# URL base do servidor Biblivre
# Exemplos:
#   - http://localhost/Biblivre5 (instalação local padrão)
#   - http://localhost:8080/Biblivre4 (Docker)
#   - https://biblioteca.exemplo.com.br/Biblivre5 (produção)
BIBSIMPLES_BIBLIVRE_URL=http://localhost/Biblivre5

# Schema do Biblivre (geralmente "default")
# Bibliotecas com múltiplas instalações podem ter schemas diferentes
BIBSIMPLES_BIBLIVRE_SCHEMA=default

# Timeout em segundos para requisições ao Biblivre
BIBSIMPLES_BIBLIVRE_TIMEOUT=30.0

# ------------------------------------------------------------------------------
# Segurança
# ------------------------------------------------------------------------------

# Chave secreta para assinatura de tokens
# IMPORTANTE: Gere uma chave aleatória forte para produção!
# Você pode gerar uma com: python -c "import secrets; print(secrets.token_hex(32))"
BIBSIMPLES_SECRET_KEY=CHANGE-ME-IN-PRODUCTION-USE-STRONG-RANDOM-KEY

# ------------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# ------------------------------------------------------------------------------

# Origens permitidas para CORS (separadas por vírgula)
# Use "*" para permitir todas (apenas em desenvolvimento!)
# Em produção, liste apenas as origens do seu frontend
BIBSIMPLES_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# ------------------------------------------------------------------------------
# Cache Local
# ------------------------------------------------------------------------------

# Habilita cache local em SQLite
BIBSIMPLES_CACHE_ENABLED=true

# Caminho do banco de dados SQLite para cache
# Caminhos relativos são baseados no diretório de execução
BIBSIMPLES_CACHE_DB_PATH=data/cache.db

# ------------------------------------------------------------------------------
# Servidor (para o script run.py)
# ------------------------------------------------------------------------------

# Host do servidor
# Use 127.0.0.1 para acesso apenas local
# Use 0.0.0.0 para acesso externo
BIBSIMPLES_HOST=127.0.0.1

# Porta do servidor
BIBSIMPLES_PORT=8000
